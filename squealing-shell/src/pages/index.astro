
<html>
  <head>
    <title>TICetario</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@200..900&display=swap" rel="stylesheet">

  </head>

<body>

<header>
<h1>TICetario</h1>
<p class="Slogan">El recetario de todos los tiqueros.</p>
</header>


<main>



  <section class="controles">

<input type="text" id="buscador" placeholder="Buscar comida...">

<select id="filtro">

<option value="todos">Todos</option>
<option value="bebida">Bebidas</option>
<option value="dulce">Dulces</option>
<option value="salada">Saladas</option>

</select>

</section>





<section class="catalogo">

<article class="card" data-categoria="bebida">
<p>Coca Zero</p>
</article>

<article class="card" data-categoria="bebida">
<p>Monster</p>
</article>

<article class="card" data-categoria="bebida">
<p>Mate</p>
</article>

<article class="card" data-categoria="bebida">
<p>Sprite</p>
</article>

<article class="card" data-categoria="bebida">
<p>Fanta</p>
</article>


<article class="card" data-categoria="bebida">
  <p>Cunington</p>
  </article>

<article class="card" data-categoria="dulce">
<p>Rasta</p>
</article>

<article class="card" data-categoria="dulce">
<p>Donsatur</p>
</article>

<article class="card" data-categoria="dulce">
<p>Oreo</p>
</article>

<article class="card" data-categoria="dulce">
<p>KitKat</p>
</article>

<article class="card" data-categoria="dulce">
<p>Kinder Bueno</p>
</article>

<article class="card" data-categoria="dulce">
  <p>Rumba</p>
  </article>

<article class="card" data-categoria="salada">
<p>Pancho</p>
</article>

<article class="card" data-categoria="salada">
<p>Empanadas</p>
</article>

<article class="card" data-categoria="salada">
<p>Sanguche de Milanesa</p>
</article>

<article class="card" data-categoria="salada">
<p>Pizza</p>
</article>

<article class="card" data-categoria="salada">
<p>Hamburguesa</p>
</article>

<article class="card" data-categoria="salada">
  <p>Lajmashin</p>
  </article>

</section>

<footer>
  <p class="Thanks">Gracias por Ver!</p>
  <p class="Foot">Credits: Tobias German</p>
  <p class="Foot">Contact: tobigerman2019@gmail.com</p>
</footer>

</main>



<script>



const buscador = document.getElementById("buscador") as HTMLInputElement
const filtro = document.getElementById("filtro") as HTMLSelectElement
const cards = document.querySelectorAll(".card") as NodeListOf<HTMLElement>




buscador.addEventListener("input", () => {

const texto = buscador.value.toLowerCase()

cards.forEach(card => {

const nombre = card.innerText.toLowerCase()

if(nombre.includes(texto)){
card.style.display = "block"
}else{
card.style.display = "none"
}

})

})






filtro.addEventListener("change", () => {

const categoria = filtro.value

cards.forEach(card => {

if(categoria === "todos"){
card.style.display="block"
return
}

if(card.dataset.categoria === categoria){
card.style.display="block"
}else{
card.style.display="none"
}

})

})


</script>



<style>

body{
font-family:"Nunito Sans", sans-serif;
background-color:black;
color:white;
margin:0;
}

h1{
font-size:50px;
text-align:center;
border:2px solid white;
border-radius:100px;
padding:10px;
}

.Slogan{
text-align:center;
font-size:30px;
}

.Thanks {
  color: black;
  text-align: center;
  font-size: 34px;
}
.Foot{
  color: black;
  text-align: center;
}

footer{
  background-color: white;
  width: 100%;
  padding: 20px 0;
}

footer p {
  margin: 0; /* ← esto es clave */
}




.controles{
text-align:center;
margin:20px;
}

input,select{
padding:10px;
font-size:16px;
margin:5px;
}





.catalogo{

display:grid;

grid-template-columns:repeat(auto-fit,minmax(200px,1fr));

gap:20px;

padding:20px;

}





.card{

background:white;

color:black;

padding:20px;

border-radius:15px;

text-align:center;

transition:0.3s;

}

.card:hover{
transform:scale(1.05);
}





@media (max-width:700px){

.catalogo{
grid-template-columns:1fr;
}

h1{
font-size:35px;
}

}

</style>

</body>
</html>
